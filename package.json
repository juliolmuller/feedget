    "@semantic-release/release-notes-generator": "^14.1.0",
    "eslint": "^9.39.4",
    "eslint-config-any": "^2.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
